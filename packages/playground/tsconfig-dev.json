{
  "compilerOptions": {
    "target": "es6",
    "module": "esnext",
    "strict": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "useDefineForClassFields": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["esnext", "dom"],
    "noImplicitAny": true,
    "downlevelIteration": true,
    "esModuleInterop": true,
    "noImplicitOverride": true,
    "baseUrl": "./",
    "paths": {
      "@textbus/platform-browser": ["../platform-browser/src/public-api.ts"],
      "@textbus/platform-node": ["../platform-node/src/public-api.ts"],
      "@textbus/core": ["../core/src/public-api.ts"],
      "@textbus/collaborate": ["../collaborate/src/public-api.ts"],
      "@textbus/adapter-viewfly": ["../adapter-viewfly/src/public-api.ts"],
      "@textbus/adapter-react": ["../adapter-react/src/public-api.ts"],
      "@textbus/adapter-vue": ["../adapter-vue/src/public-api.ts"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "@viewfly/core"
  },
  "exclude": ["packages", "dev-test", "helper", "test"]
}

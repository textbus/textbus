{
  "compilerOptions": {
    "target": "es6",
    "module": "esnext",
    "strict": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "useDefineForClassFields": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["esnext", "dom"],
    "noImplicitAny": true,
    "downlevelIteration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noImplicitOverride": true,
    "baseUrl": "./",
    "paths": {
      "@textbus/platform-browser": ["./packages/platform-browser/src/index.ts"],
      "@textbus/platform-node": ["./packages/platform-node/src/index.ts"],
      "@textbus/core": ["./packages/core/src/index.ts"],
      "@textbus/collaborate": ["./packages/collaborate/src/index.ts"],
      "@textbus/adapter-viewfly": ["./packages/adapter-viewfly/src/index.ts"],
      "@textbus/adapter-react": ["./packages/adapter-react/src/index.ts"],
      "@textbus/adapter-vue": ["./packages/adapter-vue/src/index.ts"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "@viewfly/core"
  },
  "exclude": ["packages"]
}

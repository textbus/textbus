{
  "name": "@textbus/monorepo",
  "version": "5.0.0",
  "description": "A rich text editor framework.",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:lib": "pnpm -r --if-present run build:lib",
    "changeset": "changeset",
    "dev": "pnpm --filter @textbus/playground dev",
    "docs:build": "pnpm docs:vendor && vitepress build docs && node docs/.vitepress/scripts/patch-html-stylesheet-links.mjs",
    "docs:dev": "pnpm docs:vendor && vitepress dev docs",
    "docs:preview": "pnpm docs:build && vitepress preview docs --port 5180",
    "docs:vendor": "node docs/playground/scripts/collect-monaco-types.mjs && vite build --config docs/playground/viewfly.vite.config.ts && vite build --config docs/playground/vendor.vite.config.ts",
    "lint": "eslint packages --ext .ts,.tsx --max-warnings 0",
    "lint-staged": "lint-staged",
    "prepare": "husky install",
    "publish:lib": "changeset publish",
    "serve": "pnpm --filter @textbus/playground-server start",
    "serve:yjs": "npx y-websocket HOST=localhost PORT=1234",
    "start": "pnpm dev",
    "test": "cross-env env=test jest",
    "test:coverage": "cross-env env=test jest --coverage",
    "version:lib": "changeset version"
  },
  "lint-staged": {
    "packages/*/src/**/*.{ts,tsx}": [
      "eslint --max-warnings 0"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "author": "tanbo",
  "license": "MIT",
  "keywords": [
    "textbus",
    "富文本编辑器",
    "wysiwyg",
    "wysiwyg editor",
    "rich text editor",
    "editor",
    "html editor",
    "web editor",
    "typescript editor"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@textbus/collaborate": "workspace:^",
    "@textbus/xnote": "^1.2.3",
    "@types/jest": "^27.0.3",
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^5.8.0",
    "@typescript-eslint/parser": "^5.8.0",
    "@viewfly/core": "^2.2.0 || ^3.0.0",
    "@viewfly/platform-browser": "^2.2.0 || ^3.0.0",
    "bootstrap-icons": "^1.13.1",
    "cross-env": "^7.0.3",
    "esbuild-wasm": "^0.27.2",
    "eslint": "^8.5.0",
    "husky": "^8.0.1",
    "jest": "^29.7.0",
    "jest-canvas-mock": "^2.4.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^13.0.2",
    "monaco-editor": "^0.52.2",
    "sass": "^1.70.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-swc-transform": "^1.1.1",
    "vitepress": "^1.6.4",
    "yjs": "^13.6.29"
  },
  "dependencies": {
    "@tanbo/stream": "^1.2.7",
    "reflect-metadata": "^0.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/textbus/textbus.git"
  }
}
